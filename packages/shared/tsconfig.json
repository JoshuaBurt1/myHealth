{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "declarationDir": "./dist/types",
    "emitDeclarationOnly": true,    
    "skipLibCheck": true,
    "types": ["vite/client", "node"]
  },
  "include": [
    "index.ts", 
    "env.ts", 
    "env.web.ts", 
    "env-ambient.d.ts"
  ]
}