{
  "expo": {
    "name": "MyHealth",
    "slug": "my-health-mobile",
    "version": "1.0.0",
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow MyHealth to track your steps even when the app is closed.",
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "android": {
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "package": "com.squarehexagon.myhealth"
    },
    "ios": {
      "bundleIdentifier": "com.squarehexagon.myhealth",
      "infoPlist": {
        "UIBackgroundModes": ["location", "fetch"]
      }
    }
  }
}